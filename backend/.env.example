# =========================================
# CONFIGURACION DE BASE DE DATOS POSTGRESQL
# =========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=peluqueria
DB_USER=peluqueria_user
DB_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg2://peluqueria_user:change_me@localhost:5432/peluqueria

# =========================================
# SEGURIDAD / JWT
# =========================================
# Genere una clave única y aleatoria por entorno, nunca reutilice este valor.
# Sugerencia: python -c "import secrets;print(secrets.token_urlsafe(64))"
SECRET_KEY=replace_with_a_long_random_secret_generated_per_environment
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# =========================================
# APLICACION
# =========================================
APP_NAME=Sistema de Gestion de Salon de Belleza
APP_ENV=development
DEBUG=True
API_V1_PREFIX=/api/v1

# =========================================
# CORS
# =========================================
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# =========================================
# SEGURIDAD DE LOGIN
# =========================================
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# =========================================
# PAGINACION
# =========================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# =========================================
# ASISTENTE VIRTUAL (IA) - opcional
# =========================================
# Elige el proveedor: anthropic | nvidia | groq | n8n
AI_PROVIDER=local
# Consigue tu clave en https://console.anthropic.com (cuenta propia, tiene costo por uso).
# Si la dejas vacía, el chat del sitio simplemente queda desactivado, nada más se rompe.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# NVIDIA NIM (build.nvidia.com): requiere verificacion de cuenta, tiene modelos gratis.
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# Groq (console.groq.com): registro simple con correo, plan gratis, muy rapido.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-maverick-17b-128e-instruct
CHAT_PROVIDER_TIMEOUT_SECONDS=12
CHAT_MAX_HISTORY_MESSAGES=10
CHAT_FAST_LOCAL_ENABLED=true

# Opcional: si tienes un flujo propio en n8n (ej. clasificador + busqueda + redactor con
# Groq), pega aqui la URL del webhook y el chat lo usara en vez de llamar a Anthropic
# directo. Dejalo vacio para usar Anthropic directamente (comportamiento por defecto).
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
